      "lt_6w": "acute_0_6_weeks",
      "6w_3m": "subacute_6_12_weeks",
      "gt_3m": "chronic_over_12_weeks"
    }
  },
  "nodes": [
    {
      "id": "SHOULDER_RF_001",
      "type": "red_flag_screen",
      "phase": "safety_first",
      "on_all_clear": "SHOULDER_PROFILE_001",
      "questions": [
        {
          "id": "rf_shoulder_trauma",
          "text": "Has your shoulder pain started after a fall, collision, or direct impact to the shoulder?",
          "uiType": "radio",
          "options": [
            { "label": "Yes", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.shoulderTrauma",
          "sourceInstrument": "NICE NG79",
          "if_yes": {
            "urgency": "flag_and_continue",
            "message": "We note your shoulder pain followed an injury.",
            "halt_tree": false,
            "flag": "trauma_history"
          },
          "follow_up_if_yes": {
            "id": "rf_shoulder_deformity",
            "text": "After the injury, did your shoulder visibly pop out of place, look deformed, or are you completely unable to lift your arm away from your body?",
            "uiType": "radio",
            "options": [
              { "label": "Yes — visible deformity or cannot lift arm at all", "value": "yes", "score": 0 },
              { "label": "No", "value": "no", "score": 0 }
            ],
            "allowMultiple": false,
            "mapsTo": "redFlags.shoulderDeformity",
            "if_yes": {
              "urgency": "urgent_24h",
              "message": "Your symptoms suggest a possible dislocation or significant structural injury. Please attend A&E or an urgent care clinic within 24 hours.",
              "action": "URGENT_REFERRAL_24H",
              "halt_tree": true
            },
            "if_no": { "action": "FLAG_AND_CONTINUE" }
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_shoulder_cancer",
          "text": "Have you had unexplained weight loss (more than 5 kg in 3 months), a history of cancer, or shoulder pain that is constant at night and unrelated to movement?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — one or more of these", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.shoulderCancer",
          "if_yes": {
            "urgency": "urgent_1_week",
            "message": "Your responses suggest further medical evaluation is needed. Please see your doctor within the next week.",
            "action": "URGENT_REFERRAL_1_WEEK",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_shoulder_infection",
          "text": "Is your shoulder hot, red, severely swollen, and extremely painful — particularly if you also have a fever?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — hot, red and extremely painful with fever", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.shoulderInfection",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms may indicate a joint infection. Please seek urgent medical attention within 24 hours.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_shoulder_cardiac",
          "text": "Is the pain in your left shoulder associated with chest tightness, shortness of breath, or does it come on during physical exertion?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — this matches my symptoms", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.shoulderCardiac",
          "sourceInstrument": "NICE CG95",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Shoulder pain with chest symptoms may be cardiac in origin. Please see a doctor urgently.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        }
      ]
    },

    {
      "id": "SHOULDER_PROFILE_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "SHOULDER_AGGRAVATING_001",
      "questions": [
        {
          "id": "sp_duration",
          "text": "How long have you had this shoulder pain?",
          "uiType": "radio",
          "options": [
            { "label": "Less than 6 weeks", "value": "acute_0_6_weeks", "score": 1 },
            { "label": "6 weeks to 3 months", "value": "subacute_6_12_weeks", "score": 2 },
            { "label": "More than 3 months", "value": "chronic_over_12_weeks", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "duration",
          "sourceInstrument": "Nordic MSQ"
        },
        {
          "id": "sp_severity",
          "text": "On a scale of 0 to 10, how would you rate your shoulder pain right now?",
          "uiType": "numeric_scale",
          "inputType": "numeric_scale",
          "range": [0, 10],
          "options": [],
          "allowMultiple": false,
          "maxScore": 10,
          "mapsTo": "severity",
          "sourceInstrument": "NPRS"
        },
        {
          "id": "sp_onset",
          "text": "How did your shoulder problem start?",
          "uiType": "radio",
          "options": [
            { "label": "Gradually — no specific cause", "value": "gradual", "score": 0 },
            { "label": "After an injury or accident", "value": "after_injury", "score": 2 },
            { "label": "After a specific repetitive activity (sport, work)", "value": "after_repetitive", "score": 1 },
            { "label": "I'm not sure", "value": "unknown", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "onset"
        },
        {
          "id": "sp_location",
          "text": "Where exactly does your shoulder hurt most?",
          "uiType": "radio",
          "options": [
            { "label": "Front of the shoulder", "value": "front", "score": 0 },
            { "label": "Side (lateral) of the shoulder", "value": "side", "score": 0 },
            { "label": "Back of the shoulder", "value": "back", "score": 0 },
            { "label": "Top of the shoulder (where it meets the collarbone)", "value": "top", "score": 0 },
            { "label": "Deep inside the shoulder joint", "value": "deep", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 0,
          "mapsTo": "shoulderLocation"
        },
        {
          "id": "sp_movement",
          "text": "Which movement causes the most pain or is most restricted?",
          "uiType": "radio",
          "options": [
            { "label": "Reaching overhead or above shoulder height", "value": "overhead", "score": 2 },
            { "label": "Reaching behind my back (e.g. fastening a bra, scratching back)", "value": "behind_back", "score": 1 },
            { "label": "Reaching across my body (e.g. seatbelt)", "value": "across_body", "score": 1 },
            { "label": "Lifting my arm out to the side", "value": "sideways", "score": 1 },
            { "label": "All directions are equally limited", "value": "all_directions", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "shoulderMovement"
        },
        {
          "id": "sp_night",
          "text": "Does the shoulder hurt when lying on the affected side at night?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — it wakes me or I cannot lie on that side", "value": "yes", "score": 2 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "nightPain"
        },
        {
          "id": "sp_stiffness",
          "text": "Does your shoulder feel stiff or stuck — are there movements you simply cannot do?",
          "uiType": "radio",
          "options": [
            { "label": "No — range of motion feels normal", "value": "no", "score": 0 },
            { "label": "Slightly limited — some restriction but I can manage", "value": "slightly", "score": 1 },
            { "label": "Very limited — I can barely move the shoulder in any direction", "value": "very_limited", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "shoulderStiffness"
        },
        {
          "id": "sp_neck",
          "text": "Does moving your neck (turning, tilting) change or trigger your shoulder pain?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — neck movement clearly affects my shoulder pain", "value": "yes", "score": 1 },
            { "label": "No — neck movement has no effect", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 1,
          "mapsTo": "neckInvolvement",
          "branching": {
            "yes": "SHOULDER_CERVICOGENIC_001"
          }
        }
      ]
    },

    {
      "id": "SHOULDER_CERVICOGENIC_001",
      "type": "differential_assessment",
      "phase": "investigation",
      "next": "SHOULDER_AGGRAVATING_001",
      "questions": [
        {
          "id": "cerv_arm_symptoms",
          "text": "Do you have any tingling, numbness, or weakness running down your arm — separate from the shoulder pain itself?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — tingling, numbness, or weakness in the arm", "value": "yes", "score": 2 },
            { "label": "No — just shoulder pain", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "armNeuralSx"
        },
        {
          "id": "cerv_neck_move",
          "text": "When you turn your head to the painful side and look slightly up, does this reproduce your shoulder pain or arm symptoms?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — this clearly reproduces the pain", "value": "yes", "score": 2 },
            { "label": "No change", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "cervicalReproduction"
        },
        {
          "id": "cerv_stiffness",
          "text": "Is your neck also stiff or restricted in its movement?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — my neck is also stiff", "value": "yes", "score": 1 },
            { "label": "No — just the shoulder", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 1,
          "mapsTo": "cervicalStiffness"
        }
      ]
    },

    {
      "id": "SHOULDER_AGGRAVATING_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "SHOULDER_FUNCTIONAL_001",
      "questions": [
        {
          "id": "sp_aggravating",
          "text": "What makes your shoulder pain worse? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Reaching overhead", "value": "overhead", "score": 1 },
            { "label": "Reaching behind my back", "value": "behind_back", "score": 1 },
            { "label": "Lifting objects", "value": "lifting", "score": 1 },
            { "label": "Pushing or pulling", "value": "push_pull", "score": 1 },
            { "label": "Carrying bags or heavy items", "value": "carrying", "score": 1 },
            { "label": "Nothing specific — it is always sore", "value": "constant_pain", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 4,
          "scoreCap": 3,
          "mapsTo": "aggravatingFactors"
        },
        {
          "id": "sp_easing",
          "text": "What helps ease your shoulder pain? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Rest", "value": "rest", "score": 0 },
            { "label": "Ice or cold pack", "value": "ice", "score": 0 },
            { "label": "Heat", "value": "heat", "score": 0 },
            { "label": "Gentle movement", "value": "movement", "score": 0 },
            { "label": "Medication", "value": "medication", "score": 0 },
            { "label": "Nothing really helps", "value": "nothing", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 1,
          "mapsTo": "easingFactors"
        }
      ]
    },

    {
      "id": "SHOULDER_FUNCTIONAL_001",
      "type": "functional_assessment",
      "phase": "impact_measurement",
      "next": "SHOULDER_HYPOTHESIS_001",
      "scoring": {
        "method": "sum",
        "mapsTo": "functionalScore",
        "interpretation": {
          "0-2": "minimal_functional_impact",
          "3-5": "moderate_functional_impact",
          "6-9": "severe_functional_impact"
        },
        "interpretationMapsTo": "functionalImpact"
      },
      "questions": [
        {
          "id": "fn_sleep",
          "text": "How much does your shoulder pain affect your sleep?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "Occasionally disturbs my sleep", "value": "1", "score": 1 },
            { "label": "Regularly disturbs my sleep", "value": "2", "score": 2 },
            { "label": "Severely impacts my sleep most nights", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.sleep",
          "sourceInstrument": "DASH / Oxford Shoulder Score"
        },
        {
          "id": "fn_work",
          "text": "How much does your shoulder pain affect your ability to work or carry out daily tasks?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "I modify some tasks but manage", "value": "1", "score": 1 },
            { "label": "I avoid several tasks because of the pain", "value": "2", "score": 2 },
            { "label": "I struggle with most daily tasks", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.work",
          "sourceInstrument": "DASH"
        },
        {
          "id": "fn_exercise",
          "text": "How has your shoulder pain affected your exercise or sport?",
          "uiType": "radio",
          "options": [
            { "label": "No change", "value": "0", "score": 0 },
            { "label": "I have reduced some activities", "value": "1", "score": 1 },
            { "label": "I have significantly reduced activity", "value": "2", "score": 2 },
            { "label": "I have stopped exercising entirely", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.exercise",
          "sourceInstrument": "DASH"
        }
      ]
    },

    {
      "id": "SHOULDER_HYPOTHESIS_001",
      "type": "hypothesis_generation",
      "phase": "clinical_reasoning",
      "next": "SHOULDER_ASSESS_REC_001",
      "rules": [
        {
          "id": "hyp_shoulder_impingement",
          "displayName": "Shoulder Impingement Syndrome",
          "criteria": {
            "ALL": [
              { "field": "shoulderMovement", "equals": "overhead" },
              { "field": "shoulderLocation", "containsAny": ["side", "front"] },
              { "field": "shoulderStiffness", "equals": "no" }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["FA1", "FA2", "FA5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_rc_tendinopathy",
          "displayName": "Rotator Cuff Tendinopathy",
          "criteria": {
            "ALL": [
              { "field": "nightPain", "equals": "yes" }
            ],
            "ANY": [
              { "field": "shoulderMovement", "equals": "overhead" },
              { "field": "shoulderMovement", "equals": "sideways" }
            ],
            "NONE": [
              { "field": "shoulderStiffness", "equals": "very_limited" }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["FA1", "FA2", "BB1"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_frozen",
          "displayName": "Frozen Shoulder (Adhesive Capsulitis)",
          "criteria": {
            "ALL": [
              { "field": "shoulderStiffness", "equals": "very_limited" },
              { "field": "shoulderMovement", "equals": "all_directions" },
              { "field": "duration", "containsAny": ["subacute_6_12_weeks", "chronic_over_12_weeks"] }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["FA1", "FA2", "FA5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_ac_joint",
          "displayName": "Acromioclavicular Joint Pain",
          "criteria": {
            "ALL": [
              { "field": "shoulderLocation", "equals": "top" },
              { "field": "shoulderMovement", "equals": "across_body" }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["FA1", "FA5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_calcific",
          "displayName": "Calcific Tendinopathy",
          "criteria": {
            "ALL": [
              { "field": "onset", "equals": "gradual" },
              { "field": "shoulderMovement", "equals": "overhead" },
              { "field": "severity", "greaterThan": 7 }
            ],
            "ANY": [
              { "field": "duration", "equals": "acute_0_6_weeks" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA1", "FA2"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_biceps",
          "displayName": "Biceps Tendinopathy",
          "criteria": {
            "ALL": [
              { "field": "shoulderLocation", "equals": "front" },
              { "field": "shoulderMovement", "equals": "overhead" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA1", "NN1"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_instability",
          "displayName": "Shoulder Instability",
          "criteria": {
            "ALL": [
              { "field": "onset", "equals": "after_injury" },
              { "field": "shoulderStiffness", "equals": "no" }
            ],
            "ANY": [
              { "field": "shoulderMovement", "equals": "overhead" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["BB1", "FA1", "NN1"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_cervicogenic",
          "displayName": "Cervicogenic Shoulder Pain",
          "criteria": {
            "ALL": [
              { "field": "neckInvolvement", "equals": "yes" },
              { "field": "shoulderStiffness", "equals": "no" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA3", "FA1", "NN1"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_scapular",
          "displayName": "Scapular Dyskinesis / Periscapular Pain",
          "criteria": {
            "ALL": [
              { "field": "shoulderMovement", "equals": "overhead" },
              { "field": "shoulderLocation", "containsAny": ["back", "side"] }
            ],
            "NONE": [
              { "field": "nightPain", "equals": "yes" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA1", "FA2", "FA5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_shoulder_soft_tissue",
          "displayName": "Shoulder Soft Tissue Injury",
          "criteria": {
            "ALL": [
              { "field": "onset", "equals": "after_injury" },
              { "field": "duration", "equals": "acute_0_6_weeks" },
              { "field": "shoulderStiffness", "equals": "no" }
            ],
            "NONE": [
              { "field": "nightPain", "equals": "yes" },
              { "field": "shoulderMovement", "equals": "all_directions" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA1", "FA5"],
          "contraindicatedGames": []
        }
      ]
    },

    {
      "id": "SHOULDER_ASSESS_REC_001",
      "type": "assessment_recommendation",
      "phase": "testing",
