              { "field": "duration", "equals": "acute_0_6_weeks" }
            ]
          }
        },
        {
          "ruleId": "care_shoulder_capsular",
          "pathwayId": "cp_shoulder_capsular",
          "matchCriteria": {
            "ALL": [
              { "field": "shoulderStiffness", "equals": "very_limited" },
              { "field": "shoulderMovement", "equals": "all_directions" }
            ]
          }
        },
        {
          "ruleId": "care_shoulder_guided",
          "pathwayId": "cp_shoulder_guided_rehab",
          "matchCriteria": {
            "ANY": [
              { "field": "severity", "between": [4, 6] },
              { "field": "functionalImpact", "equals": "moderate_functional_impact" }
