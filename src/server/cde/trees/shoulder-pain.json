{
  "id": "DT_SHOULDER_001",
  "version": "3.0.0",
  "moduleType": "location",
  "entryCondition": { "bodyRegion": "shoulder", "primarySymptom": "pain" },
  "architecture": {
    "type": "symptom_dominant",
    "scoringWeights": { "layer0": 0, "layer1": 0.30, "layer2": 0.30, "layer3": 0.40 }
  },
  "crossReferences": [
