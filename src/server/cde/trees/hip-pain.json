{
  "id": "DT_HIP_001",
  "version": "3.0.0",
  "moduleType": "location",
  "entryCondition": { "bodyRegion": "hip", "primarySymptom": "pain" },
  "architecture": {
    "type": "symptom_dominant",
    "scoringWeights": { "layer0": 0, "layer1": 0.30, "layer2": 0.30, "layer3": 0.40 }
  },
  "crossReferences": [
    { "tagId": "HIP_OA", "target": "hip_oa", "targetQuestion": "sp_stiffness" },
    { "tagId": "FAI", "target": "hip_fai", "targetQuestion": "sp_mechanical" }
  ],
  "valueNormalization": {
    "duration": {
      "lt_6w": "acute_0_6_weeks",
      "6w_3m": "subacute_6_12_weeks",
      "gt_3m": "chronic_over_12_weeks"
    }
  },
  "nodes": [
    {
      "id": "HIP_RF_001",
      "type": "red_flag_screen",
      "phase": "safety_first",
      "on_all_clear": "HIP_PROFILE_001",
      "questions": [
        {
          "id": "rf_hip_fracture",
          "text": "After a fall or injury, is your leg visibly shorter or rotated outward, and are you completely unable to bear any weight?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — leg appears shorter or twisted and I cannot stand", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.hipFracture",
          "if_yes": {
            "urgency": "emergency",
            "message": "Your symptoms suggest a possible hip fracture. Please call emergency services (999/112) immediately or go to A&E.",
            "action": "EMERGENCY_REFERRAL",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_hip_adolescent",
          "text": "Are you under 18 years old with hip or groin pain that came on gradually, and you have developed a limp?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — I am young, have groin pain, and a limp", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.hipAdolescent",
          "sourceInstrument": "SCFE / Perthes Screening",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Groin pain with a limp in a young person requires urgent medical evaluation to rule out SCFE or Perthes disease. Please see a doctor today.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_hip_cancer",
          "text": "Have you had unexplained weight loss, a history of cancer, or deep constant hip/groin pain that is worst at night and unrelated to movement?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — one or more of these", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.hipCancer",
          "if_yes": {
            "urgency": "urgent_1_week",
            "message": "Your responses suggest further medical evaluation is needed. Please see your doctor within the next week.",
            "action": "URGENT_REFERRAL_1_WEEK",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_hip_infection",
          "text": "Is your hip or groin hot, red, severely swollen, and extremely painful — especially if you also have a fever?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — hot, extremely painful with fever", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.hipInfection",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms may indicate a septic joint. Please seek urgent medical attention.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        }
      ]
    },

    {
      "id": "HIP_PROFILE_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "HIP_AGGRAVATING_001",
      "questions": [
        {
          "id": "sp_duration",
          "text": "How long have you had this hip or groin pain?",
          "uiType": "radio",
          "options": [
            { "label": "Less than 6 weeks", "value": "acute_0_6_weeks", "score": 1 },
            { "label": "6 weeks to 3 months", "value": "subacute_6_12_weeks", "score": 2 },
            { "label": "More than 3 months", "value": "chronic_over_12_weeks", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "duration"
        },
        {
          "id": "sp_severity",
          "text": "On a scale of 0 to 10, how would you rate your hip or groin pain right now?",
          "uiType": "numeric_scale",
          "inputType": "numeric_scale",
          "range": [0, 10],
          "options": [],
          "allowMultiple": false,
          "maxScore": 10,
          "mapsTo": "severity"
        },
        {
          "id": "sp_onset",
          "text": "How did your hip or groin pain start?",
          "uiType": "radio",
          "options": [
            { "label": "Gradually — no specific cause", "value": "gradual", "score": 0 },
            { "label": "After a specific activity (sport, exercise)", "value": "after_activity", "score": 1 },
            { "label": "After an injury or fall", "value": "after_injury", "score": 2 },
            { "label": "After surgery (hip replacement or procedure)", "value": "post_surgical", "score": 1 },
            { "label": "I'm not sure", "value": "unknown", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "onset"
        },
        {
          "id": "sp_location",
          "text": "Where do you feel most of the pain?",
          "uiType": "radio",
          "options": [
            { "label": "Deep in the groin / front of the hip", "value": "groin", "score": 0 },
            { "label": "Outer side of the hip (lateral)", "value": "lateral", "score": 0 },
            { "label": "Front of the hip (hip flexor area)", "value": "front", "score": 0 },
            { "label": "Inner groin / inner thigh", "value": "groin_medial", "score": 0 },
            { "label": "Buttock region", "value": "buttock", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 0,
          "mapsTo": "hipLocation"
        },
        {
          "id": "sp_mechanical",
          "text": "Do you experience any clicking, catching, snapping, or clunking in your hip?",
          "uiType": "radio",
          "options": [
            { "label": "No — no mechanical symptoms", "value": "none", "score": 0 },
            { "label": "Clicking or catching — sometimes locks briefly", "value": "clicking", "score": 1 },
            { "label": "Catching — feels like it gets stuck momentarily", "value": "catching", "score": 1 },
            { "label": "Snapping — a loud snap or clunk when moving", "value": "snapping", "score": 1 }
          ],
          "allowMultiple": false,
          "maxScore": 1,
          "mapsTo": "hipMechanical"
        },
        {
          "id": "sp_stiffness",
          "text": "Does your hip feel stiff, especially in the morning or after sitting?",
          "uiType": "radio",
          "options": [
            { "label": "No stiffness", "value": "no", "score": 0 },
            { "label": "Slightly stiff — eases with movement", "value": "slightly", "score": 1 },
            { "label": "Very stiff — movement is very difficult", "value": "very_difficult", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "hipStiffness"
        },
        {
          "id": "sp_weight_bearing",
          "text": "When is your hip most painful on activities involving weight bearing?",
          "uiType": "radio",
          "options": [
            { "label": "No pain during weight bearing", "value": "no", "score": 0 },
            { "label": "When walking (flat ground)", "value": "walking", "score": 1 },
            { "label": "On stairs or slopes", "value": "stairs", "score": 1 },
            { "label": "Standing on one leg", "value": "single_leg", "score": 2 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "weightBearingPain"
        },
        {
          "id": "sp_lumbar",
          "text": "Do you also have lower back pain that comes and goes along with your hip/groin pain?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — I also have lower back pain that may be related", "value": "yes", "score": 1 },
            { "label": "No — my back is fine", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 1,
          "mapsTo": "lumbarInvolvement",
          "branching": {
            "yes": "HIP_LUMBAR_001"
          }
        }
      ]
    },

    {
      "id": "HIP_LUMBAR_001",
      "type": "differential_assessment",
      "phase": "investigation",
      "next": "HIP_AGGRAVATING_001",
      "questions": [
        {
          "id": "lum_back_pattern",
          "text": "Does your back pain and hip/groin pain seem to start at the same time, or does one follow the other?",
          "uiType": "radio",
          "options": [
            { "label": "They start together — one movement triggers both", "value": "simultaneous", "score": 1 },
            { "label": "Back pain starts first, then groin pain follows", "value": "back_first", "score": 2 },
            { "label": "They seem unrelated — happen at different times", "value": "unrelated", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "lumbarHipPattern"
        },
        {
          "id": "lum_neural",
          "text": "Do you have any tingling, numbness, or pain that runs from your back down through your buttock and into your leg?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — pain or tingling travels from back into leg", "value": "yes", "score": 2 },
            { "label": "No — no leg symptoms", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "lumbarNeuralSx"
        }
      ]
    },

    {
      "id": "HIP_AGGRAVATING_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "HIP_FUNCTIONAL_001",
      "questions": [
        {
          "id": "sp_aggravating",
          "text": "What makes your hip or groin pain worse? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Hip flexion (bending the hip, sitting)", "value": "flexion", "score": 1 },
            { "label": "Lying on the affected side", "value": "lying_on_side", "score": 1 },
            { "label": "Stairs or slopes", "value": "stairs", "score": 1 },
            { "label": "Running or sprinting", "value": "sprinting", "score": 1 },
            { "label": "Single-leg activities (standing on one leg)", "value": "single_leg", "score": 1 },
            { "label": "Getting up from a chair or car", "value": "rising_from_sit", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 4,
          "scoreCap": 3,
          "mapsTo": "aggravatingFactors"
        },
        {
          "id": "sp_easing",
          "text": "What helps ease your hip or groin pain? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Rest", "value": "rest", "score": 0 },
            { "label": "Heat", "value": "heat", "score": 0 },
            { "label": "Ice", "value": "ice", "score": 0 },
            { "label": "Gentle stretching", "value": "stretching", "score": 0 },
            { "label": "Medication", "value": "medication", "score": 0 },
            { "label": "Nothing really helps", "value": "nothing", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 1,
          "mapsTo": "easingFactors"
        }
      ]
    },

    {
      "id": "HIP_FUNCTIONAL_001",
      "type": "functional_assessment",
      "phase": "impact_measurement",
      "next": "HIP_HYPOTHESIS_001",
      "scoring": {
        "method": "sum",
        "mapsTo": "functionalScore",
        "interpretation": {
          "0-2": "minimal_functional_impact",
          "3-5": "moderate_functional_impact",
          "6-9": "severe_functional_impact"
        },
        "interpretationMapsTo": "functionalImpact"
      },
      "questions": [
        {
          "id": "fn_sleep",
          "text": "How much does your hip or groin pain affect your sleep?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "Occasionally disturbs my sleep", "value": "1", "score": 1 },
            { "label": "Regularly disturbs my sleep", "value": "2", "score": 2 },
            { "label": "Severely impacts my sleep most nights", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.sleep",
          "sourceInstrument": "HOOS / Oxford Hip Score"
        },
        {
          "id": "fn_work",
          "text": "How much does your hip or groin pain affect your ability to work or do daily activities?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "I modify some tasks but manage", "value": "1", "score": 1 },
            { "label": "I avoid several tasks because of the pain", "value": "2", "score": 2 },
            { "label": "I struggle with most daily tasks", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.work",
          "sourceInstrument": "HOOS"
        },
        {
          "id": "fn_exercise",
          "text": "How has your hip or groin pain affected your exercise or sport?",
          "uiType": "radio",
          "options": [
            { "label": "No change", "value": "0", "score": 0 },
            { "label": "I have reduced some activities", "value": "1", "score": 1 },
            { "label": "I have significantly reduced activity", "value": "2", "score": 2 },
            { "label": "I have stopped exercising entirely", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.exercise",
          "sourceInstrument": "HOOS"
        }
      ]
    },

    {
      "id": "HIP_HYPOTHESIS_001",
      "type": "hypothesis_generation",
      "phase": "clinical_reasoning",
      "next": "HIP_ASSESS_REC_001",
      "rules": [
        {
          "id": "hyp_hip_oa",
          "displayName": "Hip Osteoarthritis",
          "criteria": {
            "ALL": [
              { "field": "hipLocation", "equals": "groin" },
              { "field": "duration", "equals": "chronic_over_12_weeks" },
              { "field": "hipStiffness", "containsAny": ["slightly", "very_difficult"] }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["KS1", "KS2", "KS5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_fai",
          "displayName": "Femoroacetabular Impingement (FAI)",
          "criteria": {
            "ALL": [
              { "field": "hipLocation", "equals": "groin" },
              { "field": "hipMechanical", "containsAny": ["clicking", "catching"] },
              { "field": "onset", "containsAny": ["gradual", "after_activity"] }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["KS1", "KS2", "KS5", "FA4"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_labral",
          "displayName": "Hip Labral Tear",
          "criteria": {
            "ALL": [
              { "field": "hipMechanical", "containsAny": ["clicking", "catching"] },
              { "field": "hipLocation", "equals": "groin" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["KS2", "KS5", "BB3"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_trochanteric",
          "displayName": "Greater Trochanteric Pain Syndrome",
          "criteria": {
            "ALL": [
              { "field": "hipLocation", "equals": "lateral" },
              { "field": "aggravatingFactors", "containsAny": ["lying_on_side", "stairs", "single_leg"] }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["KS1", "BB3", "KS6"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_gluteal",
          "displayName": "Gluteal Tendinopathy",
          "criteria": {
            "ALL": [
              { "field": "hipLocation", "equals": "lateral" },
              { "field": "weightBearingPain", "containsAny": ["walking", "stairs"] }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["KS1", "BB3", "KS6"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_adductor",
          "displayName": "Adductor / Groin Strain",
          "criteria": {
            "ALL": [
              { "field": "hipLocation", "equals": "groin_medial" },
              { "field": "onset", "containsAny": ["after_activity", "after_injury"] }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["KS2", "KS6", "BB1"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_flexor",
          "displayName": "Hip Flexor Tendinopathy / Strain",
          "criteria": {
            "ALL": [
              { "field": "hipLocation", "equals": "front" },
              { "field": "aggravatingFactors", "containsAny": ["flexion", "sprinting"] }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA4", "KS1", "KS5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_snapping",
          "displayName": "Snapping Hip Syndrome",
          "criteria": {
            "ALL": [
              { "field": "hipMechanical", "equals": "snapping" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["KS2", "KS1", "FA4"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_referred",
          "displayName": "Lumbar-Referred Hip Pain",
          "criteria": {
            "ALL": [
              { "field": "lumbarInvolvement", "equals": "yes" },
              { "field": "hipStiffness", "equals": "no" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["FA4", "KS3", "BB1"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_hip_post_surg",
          "displayName": "Post-Surgical Hip Pain",
          "criteria": {
            "ALL": [
              { "field": "onset", "equals": "post_surgical" }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["KS1", "KS2", "KS5", "BB1"],
          "contraindicatedGames": []
        }
      ]
    },

    {
      "id": "HIP_ASSESS_REC_001",
      "type": "assessment_recommendation",
      "phase": "testing",
      "maxGamesPerSession": 3,
      "next_after_games": "HIP_INTERPRET_001"
    },

    {
      "id": "HIP_INTERPRET_001",
      "type": "score_interpretation",
      "phase": "analysis",
      "next": "HIP_CARE_MATCH_001"
    },

    {
      "id": "HIP_CARE_MATCH_001",
      "type": "care_pathway_matching",
      "phase": "recommendation",
      "careMatchingRules": [
        {
          "ruleId": "care_hip_self_manage",
          "pathwayId": "cp_hip_self_manage",
          "matchCriteria": {
            "ALL": [
              { "field": "severity", "lessThan": 4 },
              { "field": "functionalImpact", "equals": "minimal_functional_impact" }
            ]
          }
        },
        {
          "ruleId": "care_hip_guided",
          "pathwayId": "cp_hip_guided_rehab",
          "matchCriteria": {
            "ANY": [
              { "field": "severity", "between": [4, 6] },
              { "field": "functionalImpact", "equals": "moderate_functional_impact" }
            ]
          }
        },
        {
          "ruleId": "care_hip_intensive",
          "pathwayId": "cp_hip_intensive",
          "matchCriteria": {
            "ANY": [
              { "field": "severity", "greaterThan": 6 },
              { "field": "functionalImpact", "equals": "severe_functional_impact" },
              { "field": "hipStiffness", "equals": "very_difficult" }
            ]
          }
        }
      ]
    }
  ],

  "layers": {
    "layer0": { "name": "Red Flag Screen", "questions": [] },
    "layer1": { "name": "Symptom Profile", "questions": [] },
    "layer2": { "name": "Functional Impact", "questions": [] },
    "layer3": { "name": "Risk Modifiers", "questions": [] }
  },
  "riskTierThresholds": { "low": [0, 4], "moderate": [5, 8], "high": [9, 100] },
  "hypothesisRules": [],
  "careMatchingRules": [],
  "disclaimers": {
    "standard": "Kriya QuickScan is a self-reported wellness risk tool. It is not a medical diagnosis.",
    "moduleSpecific": "Suspected hip fractures require immediate emergency services. SCFE in adolescents requires same-day medical review."
  }
}
