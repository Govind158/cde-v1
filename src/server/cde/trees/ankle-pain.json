          "3-5": "moderate_functional_impact",
          "6-9": "severe_functional_impact"
        },
        "interpretationMapsTo": "functionalImpact"
      },
      "questions": [
        {
          "id": "fn_sleep",
          "text": "How much does your ankle or foot pain affect your sleep?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "Occasionally disturbs my sleep", "value": "1", "score": 1 },
            { "label": "Regularly disturbs my sleep", "value": "2", "score": 2 },
            { "label": "Severely impacts my sleep most nights", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.sleep"
        },
        {
          "id": "fn_work",
          "text": "How much does your ankle or foot pain affect your ability to work or do daily tasks?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "I modify some tasks but manage", "value": "1", "score": 1 },
            { "label": "I avoid several tasks because of the pain", "value": "2", "score": 2 },
            { "label": "I struggle with most daily tasks", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.work"
        },
        {
          "id": "fn_exercise",
          "text": "How has your ankle or foot pain affected your exercise or sport?",
          "uiType": "radio",
          "options": [
            { "label": "No change", "value": "0", "score": 0 },
            { "label": "I have reduced some activities", "value": "1", "score": 1 },
            { "label": "I have significantly reduced activity", "value": "2", "score": 2 },
            { "label": "I have stopped exercising entirely", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.exercise"
        }
      ]
    },

    {
      "id": "ANKLE_HYPOTHESIS_001",
      "type": "hypothesis_generation",
      "phase": "clinical_reasoning",
      "next": "ANKLE_ASSESS_REC_001",
      "rules": [
        {
          "id": "hyp_ankle_lateral_sprain",
          "displayName": "Lateral Ankle Sprain",
          "criteria": {
            "ALL": [
              { "field": "onset", "equals": "twisted" },
              { "field": "ankleLocation", "equals": "outer" },
              { "field": "ankleInstability", "equals": "no" }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["BB1", "BB3", "BB4"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_ankle_instability",
          "displayName": "Chronic Ankle Instability",
          "criteria": {
            "ALL": [
              { "field": "ankleInstability", "containsAny": ["occasionally", "frequently"] },
              { "field": "sprainHistory", "equals": "three_plus" }
            ]
          },
          "confidence": "high",
          "recommendedGames": ["BB1", "BB3", "BB4", "KS5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_ankle_achilles",
          "displayName": "Achilles Tendinopathy",
          "criteria": {
            "ALL": [
              { "field": "ankleLocation", "equals": "back_achilles" },
              { "field": "duration", "containsAny": ["subacute_6_12_weeks", "chronic_over_12_weeks"] }
