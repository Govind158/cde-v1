          "displayName": "Ankle Osteoarthritis",
          "criteria": {
            "ALL": [
              { "field": "duration", "equals": "chronic_over_12_weeks" },
              { "field": "sprainHistory", "containsAny": ["one_two", "three_plus"] }
            ]
          },
          "confidence": "moderate",
          "recommendedGames": ["BB1", "BB3", "KS5"],
          "contraindicatedGames": []
        },
        {
          "id": "hyp_ankle_stress_fx",
          "displayName": "Stress Fracture",
          "criteria": {
