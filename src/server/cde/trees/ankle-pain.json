    }
  },
  "nodes": [
    {
      "id": "ANKLE_RF_001",
      "type": "red_flag_screen",
      "phase": "safety_first",
      "on_all_clear": "ANKLE_PROFILE_001",
      "questions": [
        {
          "id": "rf_ankle_weightbear",
          "text": "After an ankle injury, can you take 4 steps — even with a limp? (Ottawa Ankle Rules)",
          "uiType": "radio",
          "options": [
            { "label": "No — I cannot take 4 steps at all", "value": "cannot", "score": 0 },
            { "label": "Yes — I can take 4 steps even with difficulty", "value": "yes", "score": 0 },
            { "label": "I have not had an injury — this came on gradually", "value": "no_injury", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.ankleWeightBear",
          "sourceInstrument": "Ottawa Ankle Rules",
          "if_yes": { "action": "continue" },
          "if_no": {
            "urgency": "urgent_24h",
            "message": "Inability to weight bear after an ankle injury suggests a possible fracture (Ottawa Ankle Rules). Please attend A&E or an urgent care clinic within 24 hours for an X-ray.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          }
        },
        {
          "id": "rf_achilles_pop",
          "text": "Did you feel or hear a pop at the back of your ankle and are you now unable to stand on your toes on that side?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — I felt a pop and cannot stand on my toes", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.achillesPop",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms suggest a possible Achilles tendon rupture. Please attend A&E within 24 hours — early management is critical.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_ankle_infection",
          "text": "Is your ankle or foot hot, red, and extremely swollen with a fever — and has this come on quickly without injury?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — hot, red, swollen and I have a fever", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.ankleInfection",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms may indicate joint infection or gout. Please seek urgent medical attention.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        }
      ]
    },

    {
      "id": "ANKLE_PROFILE_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "ANKLE_AGGRAVATING_001",
      "questions": [
        {
          "id": "sp_duration",
          "text": "How long have you had this ankle or foot pain?",
          "uiType": "radio",
          "options": [
            { "label": "Less than 6 weeks", "value": "acute_0_6_weeks", "score": 1 },
            { "label": "6 weeks to 3 months", "value": "subacute_6_12_weeks", "score": 2 },
            { "label": "More than 3 months", "value": "chronic_over_12_weeks", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "duration"
        },
        {
          "id": "sp_severity",
          "text": "On a scale of 0 to 10, how would you rate your ankle or foot pain right now?",
          "uiType": "numeric_scale",
          "inputType": "numeric_scale",
          "range": [0, 10],
          "options": [],
          "allowMultiple": false,
          "maxScore": 10,
          "mapsTo": "severity"
        },
        {
          "id": "sp_onset",
          "text": "How did your ankle or foot pain start?",
          "uiType": "radio",
          "options": [
            { "label": "After a twist or roll of the ankle", "value": "twisted", "score": 2 },
            { "label": "Gradually — no specific incident", "value": "gradual", "score": 0 },
            { "label": "After a specific activity (running, sport)", "value": "after_activity", "score": 1 },
            { "label": "I'm not sure", "value": "unknown", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "onset"
        },
        {
          "id": "sp_location",
          "text": "Where is the main area of pain?",
          "uiType": "radio",
          "options": [
            { "label": "Outer ankle (lateral side)", "value": "outer", "score": 0 },
            { "label": "Inner ankle (medial side)", "value": "inner", "score": 0 },
            { "label": "Back of the ankle / Achilles tendon area", "value": "back_achilles", "score": 0 },
            { "label": "Bottom of the heel", "value": "bottom_heel", "score": 0 },
            { "label": "Top of the foot", "value": "top_foot", "score": 0 },
            { "label": "Toes or ball of the foot", "value": "toes", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 0,
          "mapsTo": "ankleLocation"
        },
        {
          "id": "sp_instability",
          "text": "Does your ankle give way or feel unstable when walking on uneven ground?",
          "uiType": "radio",
          "options": [
            { "label": "No — it feels stable", "value": "no", "score": 0 },
            { "label": "Occasionally — sometimes feels wobbly", "value": "occasionally", "score": 2 },
            { "label": "Frequently — it gives way regularly", "value": "frequently", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "ankleInstability",
          "branching": {
            "frequently": "ANKLE_INSTABILITY_001"
          }
        },
        {
          "id": "sp_sprain_history",
          "text": "Have you sprained this ankle before?",
          "uiType": "radio",
          "options": [
            { "label": "No — this is the first time", "value": "none", "score": 0 },
            { "label": "Yes — once or twice before", "value": "one_two", "score": 1 },
            { "label": "Yes — three or more times", "value": "three_plus", "score": 2 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "sprainHistory"
        },
        {
          "id": "sp_morning",
          "text": "Is the pain worst in the first few steps after getting out of bed in the morning?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — first steps are the worst, it eases after a few minutes", "value": "yes", "score": 2 },
            { "label": "No — pain is consistent throughout the day", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "morningPain"
        }
      ]
    },

    {
      "id": "ANKLE_INSTABILITY_001",
      "type": "differential_assessment",
      "phase": "investigation",
      "next": "ANKLE_AGGRAVATING_001",
      "questions": [
        {
          "id": "inst_activity",
          "text": "Does your ankle give way during specific activities like walking on uneven ground, stairs, or sports?",
          "uiType": "radio",
          "options": [
            { "label": "Only on very uneven ground or sport", "value": "uneven_sport", "score": 1 },
            { "label": "On everyday activities like stairs or slight inclines", "value": "everyday", "score": 2 },
            { "label": "Even on flat ground — unpredictably", "value": "flat_ground", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "instabilityContext"
        },
        {
          "id": "inst_balance",
          "text": "Can you stand comfortably on one leg (the affected ankle) for 10 seconds with your eyes open?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — no problem", "value": "yes", "score": 0 },
            { "label": "With difficulty — I wobble significantly", "value": "difficult", "score": 1 },
            { "label": "No — I cannot do it", "value": "no", "score": 2 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "singleLegBalance"
        }
      ]
    },

    {
      "id": "ANKLE_AGGRAVATING_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "ANKLE_FUNCTIONAL_001",
      "questions": [
        {
          "id": "sp_aggravating",
          "text": "What makes your ankle or foot pain worse? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Walking on uneven ground", "value": "uneven_ground", "score": 1 },
            { "label": "Running or jogging", "value": "running", "score": 1 },
            { "label": "Going up or down stairs", "value": "stairs", "score": 1 },
            { "label": "Wearing tight or narrow shoes", "value": "tight_shoes", "score": 1 },
            { "label": "Standing for long periods", "value": "prolonged_standing", "score": 1 },
            { "label": "First thing in the morning", "value": "morning_first_steps", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 4,
          "scoreCap": 3,
          "mapsTo": "aggravatingFactors"
        },
        {
          "id": "sp_easing",
          "text": "What helps ease your ankle or foot pain? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Rest", "value": "rest", "score": 0 },
            { "label": "Ice", "value": "ice", "score": 0 },
            { "label": "Elevation", "value": "elevation", "score": 0 },
            { "label": "Supportive footwear", "value": "supportive_shoes", "score": 0 },
            { "label": "Medication", "value": "medication", "score": 0 },
            { "label": "Nothing really helps", "value": "nothing", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 1,
          "mapsTo": "easingFactors"
        }
      ]
    },

    {
      "id": "ANKLE_FUNCTIONAL_001",
      "type": "functional_assessment",
      "phase": "impact_measurement",
      "next": "ANKLE_HYPOTHESIS_001",
      "scoring": {
        "method": "sum",
        "mapsTo": "functionalScore",
        "interpretation": {
