    }
  },
  "nodes": [
    {
      "id": "KNEE_RF_001",
      "type": "red_flag_screen",
      "phase": "safety_first",
      "on_all_clear": "KNEE_PROFILE_001",
      "questions": [
        {
          "id": "rf_knee_rapid_swelling",
          "text": "After an injury, did your knee swell up rapidly — within 2 hours — becoming very swollen and tense?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — swelled within 2 hours of injury", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.rapidKneeSwelling",
          "sourceInstrument": "Ottawa Knee Rules / Clinical guidelines",
          "if_yes": {
            "urgency": "flag_and_continue",
            "message": "Rapid knee swelling after injury (haemarthrosis) may indicate a significant internal injury such as an ACL tear or fracture. We will assess this further.",
            "halt_tree": false,
            "flag": "rapid_swelling_haemarthrosis"
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_knee_hot_joint",
          "text": "Is your knee hot, red, and extremely painful to touch — and do you have a fever or feel generally unwell?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — hot, red, very painful with fever", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.kneeHotJoint",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms may indicate a joint infection (septic arthritis), which requires immediate medical attention. Please go to A&E or call 999/112.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_knee_cancer",
          "text": "Have you had unexplained weight loss, a history of cancer, or constant knee pain that is worse at night regardless of position?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — one or more of these", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.kneeCancer",
          "if_yes": {
            "urgency": "urgent_1_week",
            "message": "Your responses suggest further medical evaluation is needed. Please see your doctor within the next week.",
            "action": "URGENT_REFERRAL_1_WEEK",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        }
      ]
    },

    {
      "id": "KNEE_PROFILE_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "KNEE_AGGRAVATING_001",
      "questions": [
        {
          "id": "sp_duration",
          "text": "How long have you had this knee pain?",
          "uiType": "radio",
          "options": [
            { "label": "Less than 6 weeks", "value": "acute_0_6_weeks", "score": 1 },
            { "label": "6 weeks to 3 months", "value": "subacute_6_12_weeks", "score": 2 },
            { "label": "More than 3 months", "value": "chronic_over_12_weeks", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "duration"
        },
        {
          "id": "sp_severity",
          "text": "On a scale of 0 to 10, how would you rate your knee pain right now?",
          "uiType": "numeric_scale",
          "inputType": "numeric_scale",
          "range": [0, 10],
          "options": [],
          "allowMultiple": false,
          "maxScore": 10,
          "mapsTo": "severity"
        },
        {
          "id": "sp_onset",
          "text": "How did your knee pain start?",
          "uiType": "radio",
          "options": [
            { "label": "Gradually — no specific cause", "value": "gradual", "score": 0 },
            { "label": "After a twisting or pivoting movement", "value": "after_twist", "score": 2 },
            { "label": "After a direct impact or collision", "value": "after_impact", "score": 2 },
            { "label": "After a fall", "value": "after_fall", "score": 2 },
            { "label": "After running or jumping (overuse)", "value": "after_running", "score": 1 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "onset"
        },
        {
          "id": "sp_location",
          "text": "Where on your knee do you feel the most pain?",
          "uiType": "radio",
          "options": [
            { "label": "Front of the knee (around or under the kneecap)", "value": "front", "score": 0 },
            { "label": "Inner (medial) side", "value": "medial", "score": 0 },
            { "label": "Outer (lateral) side", "value": "lateral", "score": 0 },
            { "label": "Back of the knee", "value": "posterior", "score": 0 },
            { "label": "All around / diffuse", "value": "all_around", "score": 0 },
            { "label": "Just below the kneecap (at the shin bone)", "value": "below_kneecap", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 0,
          "mapsTo": "kneeLocation"
        },
        {
          "id": "sp_mechanical",
          "text": "Do you experience any of the following with your knee?",
          "uiType": "radio",
          "options": [
            { "label": "None of the below", "value": "none", "score": 0 },
            { "label": "Clicking or popping (painless or mild)", "value": "clicking", "score": 1 },
            { "label": "Locking — knee gets stuck and won't fully straighten", "value": "locking", "score": 3 },
            { "label": "Giving way — knee suddenly buckles or collapses", "value": "giving_way", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "mechanicalSymptoms",
          "branching": {
            "locking": "KNEE_INTERNAL_001",
            "giving_way": "KNEE_INTERNAL_001"
          }
        },
        {
          "id": "sp_swelling",
          "text": "Has your knee swelled up?",
          "uiType": "radio",
          "options": [
            { "label": "No swelling", "value": "no", "score": 0 },
            { "label": "Mild swelling", "value": "mild", "score": 1 },
            { "label": "Rapid swelling — within 2 hours of an injury", "value": "rapid_2hrs", "score": 3 },
            { "label": "Gradual swelling — comes and goes", "value": "gradual", "score": 1 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "kneeSwelling"
        }
      ]
    },

    {
      "id": "KNEE_INTERNAL_001",
      "type": "differential_assessment",
      "phase": "investigation",
      "next": "KNEE_AGGRAVATING_001",
      "questions": [
        {
          "id": "int_mechanism",
          "text": "Was there a specific twisting, pivoting, or cutting movement at the moment of injury?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — a clear twisting motion", "value": "clear_twist", "score": 2 },
            { "label": "Yes — a pivoting or cutting movement (sport)", "value": "pivoting", "score": 2 },
            { "label": "No — it happened gradually", "value": "gradual", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "twistMechanism"
        },
        {
          "id": "int_pop",
          "text": "Did you hear or feel a pop or snap at the time of injury?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — a distinct pop or snap", "value": "yes", "score": 2 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "popSound"
        },
        {
          "id": "int_swelling_speed",
          "text": "How quickly did swelling appear after the injury?",
          "uiType": "radio",
          "options": [
            { "label": "Within 2 hours — the knee blew up quickly", "value": "within_2_hours", "score": 3 },
            { "label": "Over 24-48 hours — gradual swelling", "value": "over_24_48_hours", "score": 1 },
            { "label": "No significant swelling", "value": "no_swelling", "score": 0 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "swellingSpeed",
          "clinicalSignificance": {
            "within_2_hours": "haemarthrosis_likely_ACL_or_fracture",
            "over_24_48_hours": "effusion_likely_meniscal"
          }
        }
      ]
    },

    {
      "id": "KNEE_AGGRAVATING_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "KNEE_FUNCTIONAL_001",
      "questions": [
        {
          "id": "sp_aggravating",
          "text": "What makes your knee pain worse? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Stairs (going up or down)", "value": "stairs", "score": 1 },
            { "label": "Squatting or kneeling", "value": "squatting", "score": 1 },
            { "label": "Sitting for long periods (stiffness)", "value": "sitting", "score": 1 },
            { "label": "Running or jogging", "value": "running", "score": 1 },
            { "label": "Fully straightening the knee", "value": "extension", "score": 1 },
            { "label": "Walking on flat ground", "value": "walking", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 4,
          "scoreCap": 3,
          "mapsTo": "aggravatingFactors"
        },
        {
          "id": "sp_easing",
          "text": "What helps ease your knee pain? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "Rest", "value": "rest", "score": 0 },
            { "label": "Ice", "value": "ice", "score": 0 },
            { "label": "Elevation", "value": "elevation", "score": 0 },
            { "label": "Compression bandage", "value": "compression", "score": 0 },
            { "label": "Medication", "value": "medication", "score": 0 },
            { "label": "Nothing really helps", "value": "nothing", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 1,
          "mapsTo": "easingFactors"
        }
      ]
    },

    {
      "id": "KNEE_FUNCTIONAL_001",
      "type": "functional_assessment",
      "phase": "impact_measurement",
      "next": "KNEE_HYPOTHESIS_001",
      "scoring": {
        "method": "sum",
        "mapsTo": "functionalScore",
        "interpretation": {
          "0-2": "minimal_functional_impact",
          "3-5": "moderate_functional_impact",
          "6-9": "severe_functional_impact"
        },
        "interpretationMapsTo": "functionalImpact"
      },
      "questions": [
        {
          "id": "fn_sleep",
          "text": "How much does your knee pain affect your sleep?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "Occasionally disturbs my sleep", "value": "1", "score": 1 },
            { "label": "Regularly disturbs my sleep", "value": "2", "score": 2 },
            { "label": "Severely impacts my sleep most nights", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.sleep",
          "sourceInstrument": "KOOS / Oxford Knee Score"
        },
        {
          "id": "fn_work",
          "text": "How much does your knee pain affect your ability to work or do daily tasks?",
          "uiType": "radio",
          "options": [
            { "label": "Not at all", "value": "0", "score": 0 },
            { "label": "I modify some tasks but manage", "value": "1", "score": 1 },
            { "label": "I avoid several tasks because of the pain", "value": "2", "score": 2 },
            { "label": "I struggle with most daily tasks", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.work",
          "sourceInstrument": "KOOS"
        },
        {
          "id": "fn_exercise",
          "text": "How has your knee pain affected your exercise or sport?",
          "uiType": "radio",
          "options": [
            { "label": "No change", "value": "0", "score": 0 },
            { "label": "I have reduced some activities", "value": "1", "score": 1 },
            { "label": "I have significantly reduced activity", "value": "2", "score": 2 },
            { "label": "I have stopped exercising entirely", "value": "3", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "functionalImpact.exercise",
          "sourceInstrument": "KOOS"
        }
      ]
    },

    {
