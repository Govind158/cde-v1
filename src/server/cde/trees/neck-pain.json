          "text": "Do you experience dizziness, lightheadedness, or a spinning sensation when turning your head — separate from any headaches?",
          "uiType": "radio",
          "options": [
            { "label": "No — no dizziness when moving my neck", "value": "no", "score": 0 },
            { "label": "Yes — I sometimes feel dizzy when turning my head", "value": "yes", "score": 1 }
          ],
          "allowMultiple": false,
          "maxScore": 1,
          "mapsTo": "dizzinessPresent",
          "sourceInstrument": "Cervicogenic Dizziness Screen"
        }
