  "nodes": [
    {
      "id": "NECK_RF_001",
      "type": "red_flag_screen",
      "phase": "safety_first",
      "on_all_clear": "NECK_PROFILE_001",
      "questions": [
        {
          "id": "rf_cord_compression",
          "text": "Are you experiencing sudden severe weakness in both arms or both legs that came on rapidly, or have you lost control of your bladder or bowel?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — I am experiencing one or more of these", "value": "yes", "score": 0 },
            { "label": "No — none of the above", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.cordCompression",
          "sourceInstrument": "NICE NG79 Cervical Red Flag Guidelines",
          "if_yes": {
            "urgency": "emergency",
            "message": "Your symptoms suggest possible spinal cord compression, which requires immediate medical attention. Please call emergency services or go to your nearest emergency department now.",
            "action": "EMERGENCY_REFERRAL",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_neck_fracture",
          "text": "Has your neck pain started after a recent fall, road accident, sports collision, or direct injury to the neck?",
          "uiType": "radio",
          "options": [
            { "label": "Yes", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.neckFracture",
          "sourceInstrument": "NICE NG79",
          "if_yes": {
            "urgency": "flag_and_continue",
            "message": "We note your neck pain followed an injury.",
            "halt_tree": false,
            "flag": "trauma_history"
          },
          "follow_up_if_yes": {
            "id": "rf_neck_fracture_risk",
            "text": "Are you over 65 years old, or have you been diagnosed with osteoporosis or bone disease?",
            "uiType": "radio",
            "options": [
              { "label": "Yes", "value": "yes", "score": 0 },
              { "label": "No", "value": "no", "score": 0 }
            ],
            "allowMultiple": false,
            "mapsTo": "redFlags.neckFractureRisk",
            "if_yes": {
              "urgency": "urgent_24h",
              "message": "Given your injury history and risk factors, we recommend you see a doctor or go to A&E within 24 hours to rule out a cervical fracture.",
              "action": "URGENT_REFERRAL_24H",
              "halt_tree": true
            },
            "if_no": { "action": "FLAG_AND_CONTINUE" }
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_neck_cancer",
          "text": "Have you experienced any of the following: unexplained weight loss (more than 5 kg in 3 months), a history of cancer, or neck pain that is worst at night and does not improve with any position?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — one or more of these", "value": "yes", "score": 0 },
            { "label": "No — none of these", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.neckCancer",
          "sourceInstrument": "NICE NG79 / SIGN systemic flags",
          "if_yes": {
            "urgency": "urgent_1_week",
            "message": "Your responses suggest further medical evaluation is needed. Please see your doctor within the next week.",
            "action": "URGENT_REFERRAL_1_WEEK",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_neck_infection",
          "text": "Do you currently have a fever, or have you recently had spinal surgery, a neck infection, or used intravenous drugs?",
          "uiType": "radio",
          "options": [
            { "label": "Yes", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.neckInfection",
          "sourceInstrument": "NICE NG79",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms may indicate a possible spinal infection. We recommend urgent medical evaluation within 24 hours.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_vbi_symptoms",
          "text": "When you turn or extend your neck, do you experience any of the following: double vision, slurred speech, difficulty swallowing, sudden blackouts, or severe dizziness/drop attacks?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — one or more of these when moving my neck", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.vbiSymptoms",
          "sourceInstrument": "IFOMPT Cervical Framework / VBI Screening",
          "if_yes": {
            "urgency": "emergency",
            "message": "Your symptoms may indicate vertebrobasilar insufficiency — a vascular condition that requires immediate medical attention. Please call emergency services or go to A&E immediately.",
            "action": "EMERGENCY_REFERRAL",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        },
        {
          "id": "rf_cardiac",
          "text": "Is the pain in your left arm or shoulder associated with chest tightness, shortness of breath, or does it come on specifically during physical activity or exertion?",
          "uiType": "radio",
          "options": [
            { "label": "Yes — it fits one or more of these descriptions", "value": "yes", "score": 0 },
            { "label": "No", "value": "no", "score": 0 }
          ],
          "allowMultiple": false,
          "mapsTo": "redFlags.cardiac",
          "sourceInstrument": "NICE CG95 Cardiac Referral",
          "if_yes": {
            "urgency": "urgent_24h",
            "message": "Your symptoms may be related to your heart rather than your neck. Please see a doctor urgently — call 111 or attend A&E if symptoms are severe.",
            "action": "URGENT_REFERRAL_24H",
            "halt_tree": true
          },
          "if_no": { "action": "continue" }
        }
      ]
    },

    {
      "id": "NECK_PROFILE_001",
      "type": "symptom_profiling",
      "phase": "understanding",
      "next": "NECK_MYELOPATHY_SCREEN_001",
      "questions": [
        {
          "id": "sp_duration",
          "text": "How long have you been experiencing neck pain or stiffness?",
          "uiType": "radio",
          "options": [
            { "label": "Less than 6 weeks", "value": "acute_0_6_weeks", "score": 1 },
            { "label": "6 weeks to 3 months", "value": "subacute_6_12_weeks", "score": 2 },
            { "label": "More than 3 months", "value": "chronic_over_12_weeks", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "duration",
          "sourceInstrument": "Nordic MSQ / NDI"
        },
        {
          "id": "sp_severity",
          "text": "On a scale of 0 to 10, where 0 is no pain and 10 is the worst pain imaginable, how would you rate your neck pain right now?",
          "uiType": "numeric_scale",
          "inputType": "numeric_scale",
          "range": [0, 10],
          "options": [],
          "allowMultiple": false,
          "maxScore": 10,
          "mapsTo": "severity",
          "sourceInstrument": "NPRS (Numeric Pain Rating Scale)"
        },
        {
          "id": "sp_pattern",
          "text": "When is your neck pain or stiffness typically at its worst? Select all that apply.",
          "uiType": "multi_select",
          "options": [
            { "label": "First thing in the morning (stiffness that eases with movement)", "value": "morning_stiffness", "score": 1 },
            { "label": "After sitting at a desk, computer, or looking at a phone", "value": "sustained_posture", "score": 1 },
            { "label": "During or after physical activity", "value": "activity_related", "score": 1 },
            { "label": "Toward the end of the day", "value": "end_of_day", "score": 1 },
            { "label": "It's constant — never really goes away", "value": "constant", "score": 2 },
            { "label": "It gets better with gentle movement after resting", "value": "after_rest_then_better", "score": 1 }
          ],
          "allowMultiple": true,
          "maxScore": 6,
          "scoreCap": 3,
          "mapsTo": "painPattern",
          "sourceInstrument": "NDI / STarT MSK"
        },
        {
          "id": "sp_radiation",
          "text": "Does your pain stay in your neck, or does it travel to other areas?",
          "uiType": "radio",
          "options": [
            { "label": "Stays in my neck and/or shoulders only", "value": "localized", "score": 0 },
            { "label": "Travels into my shoulder or upper arm (but not below elbow)", "value": "arm_above_elbow", "score": 2 },
            { "label": "Travels down my arm below the elbow or into my hand/fingers", "value": "arm_below_elbow", "score": 3 },
            { "label": "Travels up into my head causing headaches", "value": "headache", "score": 1 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "radiation",
          "sourceInstrument": "NDI / Nordic MSQ",
          "branching": {
            "arm_above_elbow": "NECK_RADICULAR_001",
            "arm_below_elbow": "NECK_RADICULAR_001",
            "headache": "NECK_HEADACHE_001"
          }
        }
      ]
    },

    {
      "id": "NECK_RADICULAR_001",
      "type": "differential_assessment",
      "phase": "investigation",
      "next": "NECK_MYELOPATHY_SCREEN_001",
      "hypothesisModifiers": {
