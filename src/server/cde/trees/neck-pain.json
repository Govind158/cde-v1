          "increases_confidence": "neck_radiculopathy",
          "recommended_games": ["NN1", "NN2", "FA3"]
        }
      },
      "questions": [
        {
          "id": "rad_dermatome",
          "text": "Where in your arm do you feel the pain, numbness, or tingling?",
          "uiType": "radio",
          "options": [
            { "label": "Shoulder and outer upper arm", "value": "C5", "score": 1 },
            { "label": "Thumb side of forearm and thumb", "value": "C6", "score": 2 },
            { "label": "Middle finger and back of forearm", "value": "C7", "score": 2 },
            { "label": "Little finger and inner forearm", "value": "C8", "score": 2 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "cervicalDermatome",
          "sourceInstrument": "Clinical cervical dermatome mapping"
        },
        {
          "id": "rad_neuro",
          "text": "Are you experiencing any of the following in your arm or hand?",
          "uiType": "radio",
          "options": [
            { "label": "No — just pain radiating down the arm", "value": "none", "score": 0 },
            { "label": "Numbness or tingling only", "value": "sensory", "score": 1 },
            { "label": "Weakness in my arm or hand", "value": "motor", "score": 3 },
            { "label": "Both numbness/tingling AND weakness", "value": "sensorimotor", "score": 3 }
          ],
          "allowMultiple": false,
          "maxScore": 3,
          "mapsTo": "neuroDeficit",
          "sourceInstrument": "Neurological screening — upper limb",
          "branching": {
            "motor": "__follow_up_rad_progressive",
            "sensorimotor": "__follow_up_rad_progressive"
          },
          "follow_up_if_yes": {
            "id": "rad_progressive",
            "text": "Is the weakness in your arm or hand getting progressively worse over the past few days or weeks?",
            "uiType": "radio",
            "options": [
              { "label": "Yes — it is getting worse", "value": "yes", "score": 0 },
              { "label": "No — it has been stable", "value": "no", "score": 0 }
            ],
            "allowMultiple": false,
            "mapsTo": "progressiveWeakness",
            "if_yes": {
              "urgency": "urgent_48h",
              "message": "Progressive arm weakness requires medical assessment within 48 hours. Please contact your doctor or attend an urgent care clinic promptly.",
              "action": "URGENT_REFERRAL_48H",
              "halt_tree": true
            },
            "if_no": { "action": "RECOMMEND_CLINICAL_ASSESSMENT_1_WEEK" }
          }
        },
        {
          "id": "rad_spurling",
          "text": "Does tilting your head toward the painful side and looking slightly upward increase your arm pain, tingling, or numbness?",
          "uiType": "radio",
          "options": [
            { "label": "No — no change in arm symptoms", "value": "no", "score": 0 },
            { "label": "Mild increase in symptoms", "value": "mild", "score": 1 },
            { "label": "Yes — it clearly reproduces my arm symptoms", "value": "clearly_reproduces", "score": 2 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "spurlingProxy",
          "sourceInstrument": "Spurling's test proxy (self-reported)"
        },
        {
          "id": "rad_grip",
          "text": "Have you noticed any weakness or difficulty when gripping objects (like opening jars or turning door handles)?",
          "uiType": "radio",
          "options": [
            { "label": "No — grip strength feels normal", "value": "no", "score": 0 },
            { "label": "Mild — slightly weaker than usual", "value": "mild", "score": 1 },
            { "label": "Significant — I frequently drop things", "value": "significant", "score": 2 }
          ],
          "allowMultiple": false,
          "maxScore": 2,
          "mapsTo": "gripWeakness",
          "sourceInstrument": "Functional grip screen"
        }
      ]
    },

