          "uiType": "radio",
          "options": [
            { "label": "No — no such sensation", "value": "no", "score": 0 },
            { "label": "Yes — I experience this when bending my neck forward", "value": "yes", "score": 4 }
          ],
          "allowMultiple": false,
          "maxScore": 4,
          "mapsTo": "lhermittes",
