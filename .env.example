# Kriya Pain Diagnostics — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — NEVER commit real keys.

# OpenAI API key used by /api/extract for free-text → structured field extraction.
# Required. The LLM layer runs server-side only; the key is never shipped to the browser.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
