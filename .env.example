# Kriya Pain Diagnostics — Environment Variables
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored — NEVER commit real keys.

# OpenAI API key used by /api/extract for free-text → structured field extraction.
# Required. The LLM layer runs server-side only; the key is never shipped to the browser.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Release stage gating (CDE v4.1).
#   'uat'  — Pre-release / clinical UAT.  Persistent yellow banner +
#            open-blockers panel on every result card.  DEFAULT (fail-safe).
#   'prod' — Public production.  No pre-release markers.
#            ONLY set to 'prod' once the production go-live checklist in
#            src/lib/release-stage.ts has all 7 items signed off.
NEXT_PUBLIC_KRIYA_RELEASE_STAGE=uat
